 * Demetra v2 — parte comune alle due metà (HWMv2, ZMK v0.4).
 * Modulo BMD-340 (nRF52840), bootloader Adafruit, nessun quarzo 32kHz (LFCLK RC).
 */

/dts-v1/;
#include <nordic/nrf52840_qiaa.dtsi>
#include <common/nordic/nrf52840_uf2_boot_mode.dtsi>

#include <dt-bindings/zmk/matrix_transform.h>
#include "demetra_v2-layouts.dtsi"

&physical_layout0 {
    transform = <&default_transform>;
};

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,physical-layout = &physical_layout0;
        zephyr,code-partition = &code_partition;
        zephyr,sram = &sram0;
        zephyr,flash = &flash0;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <34>;
        rows = <1>;
        map = <
            RC(0,0)  RC(0,1)  RC(0,2)  RC(0,3)  RC(0,4)     RC(0,17) RC(0,18) RC(0,19) RC(0,20) RC(0,21)
            RC(0,5)  RC(0,6)  RC(0,7)  RC(0,8)  RC(0,9)     RC(0,22) RC(0,23) RC(0,24) RC(0,25) RC(0,26)
            RC(0,10) RC(0,11) RC(0,12) RC(0,13) RC(0,14)    RC(0,27) RC(0,28) RC(0,29) RC(0,30) RC(0,31)
                                      RC(0,15) RC(0,16)     RC(0,32) RC(0,33)
        >;
    };
};

/* DCDC su entrambi gli stadi (induttori integrati nel BMD-340, modulo in
   High Voltage mode). REG0 (VDDH->VDD): basta status okay — il binding HV non
   ha la proprietà mode, soc.c attiva DCDCEN0 se il nodo è abilitato.
   REG1 (VDD->core): via regulator-initial-mode, come glove80. */
&reg0 {
    status = "okay";
};

&reg1 {
    regulator-initial-mode = <NRF5X_REG_MODE_DCDC>;
};

&gpio0 { status = "okay"; };
&gpio1 { status = "okay"; };
&gpiote { status = "okay"; };

zephyr_udc0: &usbd {
    status = "okay";
};

&flash0 {
    partitions {
        compatible = "fixed-partitions";
        #address-cells = <1>;
        #size-cells = <1>;

        sd_partition: partition@0 {
            reg = <0x00000000 0x00026000>;
        };
        code_partition: partition@26000 {
            reg = <0x00026000 0x000c6000>;
        };
        storage_partition: partition@ec000 {
            reg = <0x000ec000 0x00008000>;
        };
        boot_partition: partition@f4000 {
            reg = <0x000f4000 0x0000c000>;
        };
    };
};
